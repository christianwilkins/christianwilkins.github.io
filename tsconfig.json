{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "types": ["vite/client"],
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "paths": {
      "@/*": ["./src/*"],
      "next/link": ["./src/compat/next-link.tsx"],
      "next/navigation": ["./src/compat/next-navigation.ts"],
      "next/dynamic": ["./src/compat/next-dynamic.tsx"],
      "next/script": ["./src/compat/next-script.tsx"]
    }
  },
  "include": [
    "src",
    "vite.config.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules",
    "next.config.ts",
    "src/app/api/**",
    "src/app/layout.tsx",
    "src/app/sitemap.ts",
    "src/app/robots.ts",
    "src/app/opengraph-image.tsx",
    "src/app/twitter-image.tsx",
    "src/app/ai.txt/**",
    "src/app/llms.txt/**",
    "src/app/rss.xml/**",
    "src/app/lab/books/**",
    "src/app/lab/supabase-tester/**",
    "src/components/lab/**",
    "src/lib/auth.ts",
    "src/lib/auth.test.ts"
  ]
}
